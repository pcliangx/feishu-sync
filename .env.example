# Feishu API credentials
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Target folder for new documents
# If not set, documents will be created in the root of My Space
FEISHU_FOLDER_TOKEN=

# Optional: Wiki space ID (if creating in wiki)
FEISHU_WIKI_SPACE_ID=
