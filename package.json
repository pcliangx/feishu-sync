{
  "name": "feishu-sync",
  "version": "1.0.0",
  "description": "Sync Markdown files to Feishu documents with Mermaid diagram rendering",
  "main": "dist/index.js",
  "type": "module",
  "bin": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "pkg": "pkg dist/index.js",
    "pkg:mac": "pkg dist/index.js --targets node18-macos-x64",
    "pkg:linux": "pkg dist/index.js --targets node18-linux-x64",
    "pkg:win": "pkg dist/index.js --targets node18-win-x64",
    "pkg:all": "pkg dist/index.js --targets node18-macos-x64,node18-linux-x64,node18-win-x64"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@sparticuz/chromium": "^147.0.0",
    "@types/graphviz": "^0.0.39",
    "graphviz": "^0.0.9",
    "marked": "^12.0.0",
    "mermaid": "^10.9.0",
    "puppeteer-core": "^24.40.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
